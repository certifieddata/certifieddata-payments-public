{
  "profile_id": "certified-artifact-purchase",
  "title": "Certified Artifact Purchase",
  "version": "1.0.0",
  "description": "End-to-end flow for purchasing a certified AI artifact with provenance linking. Attaches certificate_id, artifact_id, and decision_record_id to the transaction before capture.",
  "required_endpoints": [
    "POST /v1/payees",
    "POST /v1/payment-intents",
    "POST /v1/transactions",
    "POST /v1/transactions/{id}/attach-links",
    "POST /v1/transactions/{id}/capture"
  ],
  "required_schemas": ["Payee", "PaymentIntent", "Transaction", "ProvenanceLinkSet", "Receipt"],
  "expected_events": [
    "payee.created",
    "payment_intent.created",
    "transaction.created",
    "transaction.links_attached",
    "transaction.captured"
  ],
  "required_provenance_links": ["certificate_id", "artifact_id"],
  "recommended_provenance_links": ["decision_record_id", "receipt_hash"],
  "recommended_provenance_metadata": ["cdp:workflow_id", "cdp:source_system", "partner:invoice_ref"],
  "provenance_immutability_note": "Attach provenance links BEFORE capture. After capture, provenance is immutable (error: provenance.immutable_after_capture).",
  "example_files": ["./examples/certified-artifact-purchase/create-transaction-with-links.ts"],
  "docs": ["./docs/provenance-linking.md", "./docs/transactions.md", "./docs/receipts.md"],
  "state_machines": [
    "./schemas/state-machines/payment-intent.state-machine.json",
    "./schemas/state-machines/transaction.state-machine.json"
  ],
  "idempotency_required": true,
  "idempotency_guidance": "Use a stable idempotency key per operation, e.g. based on your internal order ID."
}
