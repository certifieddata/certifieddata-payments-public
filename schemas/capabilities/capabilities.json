{
  "version": "1.0.0",
  "api_version": "2025-01-01",
  "environments": ["sandbox", "live"],
  "environment_selection": {
    "mechanism": "api_key_prefix",
    "test_key_prefix": "cdp_test_",
    "live_key_prefix": "cdp_live_",
    "host": "https://certifieddata.io",
    "note": "Both environments route through the same host. The key prefix (cdp_test_ vs cdp_live_) controls routing — there is no separate sandbox hostname."
  },
  "resources": [
    "payee", "payee_alias", "payout_destination", "customer", "invoice",
    "payment_intent", "transaction", "settlement", "refund", "event", "webhook_endpoint"
  ],
  "payment_rails": ["stripe", "usdc_base", "usdc_ethereum", "eth_ethereum"],
  "event_types": [
    "payee.created", "payee.updated", "payee.alias.created",
    "payout_destination.created", "payout_destination.updated",
    "invoice.created", "invoice.finalized", "invoice.voided",
    "payment_intent.created", "payment_intent.confirmed", "payment_intent.canceled",
    "transaction.created", "transaction.captured", "transaction.canceled", "transaction.links_attached",
    "settlement.created", "settlement.submitted", "settlement.succeeded", "settlement.failed",
    "refund.created", "refund.succeeded", "refund.failed",
    "webhook_endpoint.created", "webhook_endpoint.updated"
  ],
  "provenance_link_types": [
    "artifact_id", "certificate_id", "decision_record_id", "dataset_id", "model_id",
    "output_id", "receipt_hash", "external_reference", "provenance_metadata"
  ],
  "idempotency": {
    "supported": true,
    "header_name": "Idempotency-Key",
    "required_endpoints": [
      "POST /v1/payees",
      "POST /v1/transactions",
      "POST /v1/settlements",
      "POST /v1/refunds"
    ],
    "recommended_endpoints": [
      "POST /v1/payment-intents",
      "POST /v1/invoices"
    ]
  },
  "webhooks": {
    "supported": true,
    "signature_algorithm": "hmac-sha256",
    "signature_header": "CDAC-Signature",
    "timestamp_header": "CDAC-Timestamp",
    "timestamp_tolerance_seconds": 300
  },
  "pagination": {
    "default_limit": 20,
    "max_limit": 100,
    "cursor_based": true
  },
  "provenance_metadata": {
    "max_keys": 20,
    "max_value_length": 256,
    "namespacing_required": true,
    "allowed_namespaces": ["cdp:", "partner:", "ext:"]
  },
  "per_resource_mutability": {
    "transaction": { "mutable_after_capture": false, "provenance_links_mutable_until": "captured" },
    "receipt": { "mutable": false },
    "settlement": { "cancelable_before_submit": true }
  },
  "sandbox_limits": {
    "max_amount_cents": 100000,
    "max_amount_display": "$1,000.00",
    "note": "Test-mode transactions (cdp_test_ keys) above this amount return HTTP 400 with code sandbox_amount_limit_exceeded. Live-mode transactions (cdp_live_) are not constrained by this limit."
  },
  "receipt_verification": {
    "algorithm": "sha256-stable-json",
    "canonicalization": "lexicographic key sort, no whitespace, undefined excluded, null preserved, UTF-8",
    "signing_algorithm": "Ed25519",
    "signature_encoding": "base64 (standard, not URL-safe)",
    "docs": "/docs/verification-algorithm.md"
  },
  "sdk_versions": { "typescript": "0.1.0", "python": "0.1.0" },
  "mock_server_supported_resources": [
    "payee", "payee_alias", "payout_destination", "payment_intent",
    "transaction", "settlement", "refund", "event"
  ]
}
