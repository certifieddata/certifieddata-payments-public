{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://certifieddata.io/schemas/resources/settlement/v1",
  "title": "Settlement",
  "description": "A payout batch from CertifiedData to a Payee, settling one or more captured transactions. Settlements may be canceled before submission.",
  "type": "object",
  "required": ["id", "object", "payee_id", "amount", "currency", "status", "transaction_ids", "created_at", "updated_at", "livemode"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^stl_",
      "examples": ["stl_01HZXB4H0Y2XCN1YZX5Y8F2Q6V"]
    },
    "object": { "type": "string", "const": "settlement" },
    "payee_id": { "type": "string", "pattern": "^py_" },
    "destination_id": {
      "type": ["string", "null"],
      "pattern": "^pydst_",
      "description": "The payout destination to use. If null, the payee's default destination is used."
    },
    "amount": { "type": "integer", "minimum": 0, "description": "Total settlement amount in minor units." },
    "currency": { "type": "string", "pattern": "^[A-Z]{3}$" },
    "status": {
      "type": "string",
      "enum": ["draft", "submitted", "processing", "succeeded", "failed", "canceled"]
    },
    "transaction_ids": {
      "type": "array",
      "items": { "type": "string", "pattern": "^tx_" },
      "description": "Transactions being settled. Must all be in succeeded status."
    },
    "provenance": {
      "$ref": "https://certifieddata.io/schemas/resources/provenance-link-set/v1",
      "description": "Optional provenance links for this settlement batch."
    },
    "metadata": {
      "type": ["object", "null"],
      "maxProperties": 20,
      "propertyNames": { "pattern": "^(cdp:|partner:|ext:).{1,60}$" },
      "additionalProperties": { "type": "string", "maxLength": 256 }
    },
    "submitted_at": { "type": ["string", "null"], "format": "date-time" },
    "succeeded_at": { "type": ["string", "null"], "format": "date-time" },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" },
    "livemode": { "type": "boolean" }
  },
  "additionalProperties": false,
  "examples": [
    {
      "id": "stl_01HZXB4H0Y2XCN1YZX5Y8F2Q6V",
      "object": "settlement",
      "payee_id": "py_01HZX8E77KN1KZ9M2G5D5Q4N4V",
      "destination_id": "pydst_01HZXA1NQJRTGQ6J8DY4CZ9V4F",
      "amount": 25000,
      "currency": "USD",
      "status": "draft",
      "transaction_ids": ["tx_01HZX8KHJNR4D42R6G4W4Q0Y0V"],
      "metadata": { "cdp:settlement_batch": "batch_001" },
      "submitted_at": null,
      "succeeded_at": null,
      "created_at": "2026-04-06T18:47:00Z",
      "updated_at": "2026-04-06T18:47:00Z",
      "livemode": false
    }
  ]
}
