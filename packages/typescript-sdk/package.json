{
  "name": "@certifieddata/payments",
  "version": "0.1.0",
  "description": "CertifiedData Agent Commerce TypeScript SDK",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "node --test dist/**/*.test.js",
    "lint": "tsc --noEmit"
  },
  "engines": { "node": ">=18" },
  "keywords": ["certifieddata", "payments", "provenance", "ai", "sdk"],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0"
  }
}
